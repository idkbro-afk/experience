local HCenter = Enum.HorizontalAlignment.Center
local VCenter = Enum.VerticalAlignment.Center
local HLeft   = Enum.HorizontalAlignment.Left
local VTop    = Enum.VerticalAlignment.Top
local FillH   = Enum.FillDirection.Horizontal
local FillV   = Enum.FillDirection.Vertical
local SLayout = Enum.SortOrder.LayoutOrder
local SName   = Enum.SortOrder.Name
local ASMBorder     = Enum.ApplyStrokeMode.Border
local LJMRound      = Enum.LineJoinMode.Round

local function Corner(Scale, Offset, Parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(Scale or 0, Offset or 0)
    c.Parent = Parent
    return c
end

local function ListLayout(parent, scale, offset, HZ, VT, SO, FILL)
    local list = Instance.new("UIListLayout")
    list.Padding           = UDim.new(scale or 0, offset or 0)
    list.FillDirection     = FILL or FillH
    list.HorizontalAlignment = HZ or HCenter
    list.VerticalAlignment   = VT or VCenter
    list.SortOrder         = SO or SName
    list.Parent            = parent
    return list
end

local function Stroke(parent, ASM, R, G, B, LJM, Tn, Transy)
    local s = parent:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
    s.ApplyStrokeMode = ASM or ASMBorder
    s.Color           = Color3.fromRGB(R or 255, G or 255, B or 255)
    s.LineJoinMode    = LJM or LJMRound
    s.Thickness       = Tn or 1
    s.Transparency    = Transy or 0
    s.Parent          = parent
    return s
end

